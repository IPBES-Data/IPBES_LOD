        <http://ontology.ipbes.net/report/ref/2333076/items/WSCL4JFB>,
        <http://ontology.ipbes.net/report/ref/2333076/items/XWLGXM46>,
        <http://ontology.ipbes.net/report/ref/2333076/items/Y6CW8FEW>,
        <http://ontology.ipbes.net/report/ref/2333076/items/Y7KA65D3>,
        <http://ontology.ipbes.net/report/ref/2333076/items/YYIDSC9D>,
        <http://ontology.ipbes.net/report/ref/2333076/items/Z27TU9CS>,
        <http://ontology.ipbes.net/report/ref/2333076/items/ZISQUVA9> ;
