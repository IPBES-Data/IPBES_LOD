        <http://ontology.ipbes.net/report/ref/2333088//items/BM7HRPDL>,
        <http://ontology.ipbes.net/report/ref/2333088//items/BPSQE3RE>,
        <http://ontology.ipbes.net/report/ref/2333088//items/C7HE4NQY>,
        <http://ontology.ipbes.net/report/ref/2333088//items/EB924XRT>,
        <http://ontology.ipbes.net/report/ref/2333088//items/F6Y8YBLC>,
        <http://ontology.ipbes.net/report/ref/2333088//items/FE6XUG8Z>,
        <http://ontology.ipbes.net/report/ref/2333088//items/FLSMFKUL>,
        <http://ontology.ipbes.net/report/ref/2333088//items/GHI4TQ78>,
        <http://ontology.ipbes.net/report/ref/2333088//items/HWDJJYJ3>,
        <http://ontology.ipbes.net/report/ref/2333088//items/JLR5VCU9>,
